generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BillStatus {
  unpaid
  paid
}

enum BillCategory {
  spaylater
  electricity
  water
  internet
  grocery
  other
}

enum Installment {
  bnpl
  three_months
  six_months
  twelve_months
}

model Bill {
  id          String       @id @default(uuid())
  name        String
  provider    String?
  source      String? // "spaylater" | "manual" | "other" (free-form)
  amount      Decimal      @db.Decimal(12, 2) // use Decimal to avoid float issues
  currency    String       @default("PHP")
  dueDate     DateTime // store as date
  status      BillStatus   @default(unpaid)
  paidAt      DateTime?
  notes       String?
  category    BillCategory
  installment Installment?
  assignee    String       @default("none")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueDate])
  @@index([status])
  @@index([category, assignee])
}

model Assignee {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String @id @default(uuid())
  email    String @unique
  password String // hashed password
  name     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// New models for budget tracking
enum TransactionType {
  inflow
  outflow
}

enum CategoryType {
  income
  expense
}

model Category {
  id        String        @id @default(uuid())
  name      String        @unique
  type      CategoryType
  color     String?       // For UI visualization
  icon      String?       // Optional icon name

  transactions Transaction[]
  budgets      Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("PHP")
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  date        DateTime
  description String?
  billId      String?         // Optional link to existing bills
  assignee    String?         // Optional assignee for shared expenses

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type, categoryId])
  @@index([assignee])
}

model Budget {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("PHP")
  period     String   @default("monthly") // "monthly" | "yearly"
  startDate  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, period])
}
